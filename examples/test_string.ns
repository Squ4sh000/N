// examples/test_string.ns - Testing string library
import "lib/string.ns";

print("Testing String Library:");

var myStr = "Hello N Language!";
print("Original string: ", myStr);

// 测试 len() 内置函数
print("len(", myStr, ") = ", len(myStr));

// 测试 repeat 库函数
var star = "*";
var line = repeat(star, 10);
print("Repeat 10 times '*': ", line);

// 测试字符串拼接
var part1 = "N Language";
var part2 = " is awesome!";
print("Concat: ", concat(part1, part2));

// 混合测试
for (var i = 1; i <= 5; i = i + 1) {
    print(repeat(">", i), " Level ", i);
}
