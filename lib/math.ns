// math.ns - N Language Standard Math Library

fn abs(n) {
    if (n < 0) {
        return 0 - n;
    }
    return n;
}

fn square(n) {
    return n * n;
}

fn max(a, b) {
    if (a > b) {
        return a;
    }
    return b;
}

fn min(a, b) {
    if (a < b) {
        return a;
    }
    return b;
}
