{
    "name": "n-lang",
    "displayName": "N Language Support",
    "description": "Language support for N Script (.ns)",
    "version": "1.0.0",
    "publisher": "Squ4sh000",
    "icon": "images/logo.ico",
    "engines": {
        "vscode": "^1.60.0"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Squ4sh000/N"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "N",
        "N Language",
        "N Script",
        "ns",
        "Squ4sh000"
    ],
    "activationEvents": [
        "onLanguage:n-lang"
    ],
    "main": "./extension.js",
    "contributes": {
        "languages": [
            {
                "id": "n-lang",
                "aliases": [
                    "N Language",
                    "n"
                ],
                "extensions": [
                    ".ns"
                ],
                "icon": {
                    "light": "./images/logo.ico",
                    "dark": "./images/logo.ico"
                },
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "n-lang",
                "scopeName": "source.n",
                "path": "./syntaxes/n.tmLanguage.json"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "n-lang.runFile",
                    "when": "resourceExtname == .ns",
                    "group": "navigation"
                }
            ]
        },
        "commands": [
            {
                "command": "n-lang.runFile",
                "title": "Run N Script",
                "icon": "$(play)"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "N Language Configuration",
            "properties": {
                "n-lang.executablePath": {
                    "type": "string",
                    "default": "n",
                    "description": "Path to the N language interpreter (n.exe)."
                }
            }
        }
    }
}
